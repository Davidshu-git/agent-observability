# Database
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=agent_obs
POSTGRES_USER=agent_obs
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql+asyncpg://agent_obs:changeme@db:5432/agent_obs

# API
API_HOST=0.0.0.0
API_PORT=8000

# Web
NEXT_PUBLIC_API_URL=http://localhost:8000

# mhxy adapter — host path to mount into container
MHXY_HOST_LOG_DIR=/path/to/mhxy/logs/sessions

# omnibot adapter — host paths to mount into container
OMNIBOT_STOCK_HOST_LOG_DIR=/path/to/omnibot/data/stock/observability/sessions
OMNIBOT_EHS_HOST_LOG_DIR=/path/to/omnibot/data/ehs/observability/sessions
